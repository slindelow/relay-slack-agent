# Slack app credentials
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=

# Database
DATABASE_URL=postgresql+asyncpg://relay:relay@localhost:5432/relay
TEST_DATABASE_URL=postgresql+asyncpg://relay:relay@localhost:5432/relay_test

# Redis / Celery
REDIS_URL=redis://localhost:6379/0

# Token encryption - must be exactly 64 hex chars (32 bytes / 256 bits)
TOKEN_ENCRYPTION_KEY=

# Anthropic
ANTHROPIC_API_KEY=
CLASSIFIER_MODEL=claude-3-5-haiku-latest
DRAFT_MODEL=claude-3-5-sonnet-latest
SUMMARY_MODEL=claude-haiku-4-5-20251001

# App
APP_BASE_URL=https://your-app.example.com
ENVIRONMENT=development
SENTRY_DSN=
BETA_DEPLOY_TARGET=railway
KMS_PROVIDER=none
KMS_KEY_ID=

# Classifier thresholds - update after validation
CLASSIFIER_OPEN_THRESHOLD=0.85
CLASSIFIER_CANDIDATE_THRESHOLD=0.60
CLASSIFIER_VARIANT=a

# HubSpot OAuth
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_REDIRECT_URI=https://your-app.example.com/hubspot/oauth_redirect

# Embeddings / source connectors
EMBEDDING_PROVIDER=voyage
VOYAGE_API_KEY=
OPENAI_API_KEY=
GOOGLE_DRIVE_CREDENTIALS_JSON=
GITHUB_TOKEN=

# GDPR erasure endpoint
ERASURE_SECRET=

# Contact emails for public legal pages (shown in /privacy and /terms)
PRIVACY_CONTACT_EMAIL=privacy@your-domain.com
LEGAL_CONTACT_EMAIL=legal@your-domain.com
